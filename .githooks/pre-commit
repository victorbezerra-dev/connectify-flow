#!/bin/sh
set -e

echo "Checking changed Kotlin files..."

FILES=$(git diff --cached --name-only --diff-filter=ACM -- '*.kt' '*.kts')

if [ -z "$FILES" ]; then
  echo "No Kotlin files to check"
  exit 0
fi

echo "Changed files:"
echo "$FILES"

echo "Running ktlint (format)..."
./gradlew ktlintFormat

echo "Running detekt..."
./gradlew detekt

echo "All checks passed"
exit 0